{
  "devDependencies": {
    "husky": "^8.0.3",
    "lint-staged": "^14.0.1"
  },
  "scripts": {
    "prepare": "husky install",
    "prettier:ui": "cd ui && npm run prettier:write",
    "eslint:ui": "cd ui && npm run lint:fix",
    "lint-tsc:ui": "cd ui && npm run lint-tsc:staged"
  },
  "lint-staged": {
    "ui/**/*.{ts,tsx}": [
      "npm run eslint:ui",
      "npm run lint-tsc:ui"
    ],
    "ui/**/": [
      "npm run prettier:ui"
    ]
  }
}
