FROM amazoncorretto:21
ARG MAINTAINER="Scott Logic"
ARG PORT=8080
ARG CONF_FILE_NAME
ARG APP_EXECUTABLE_NAME

EXPOSE ${PORT}

ENTRYPOINT /entrypoint.sh $HACKATHON_SERVER_BIN server $HACKATHON_SERVER_CONF_FILE

ENV \
    HACKATHON_SERVER_BIN=/hackathon/bin/${APP_EXECUTABLE_NAME} \
    HACKATHON_SERVER_CONF_FILE=/hackathon/conf/${CONF_FILE_NAME}
COPY entrypoint.sh /
COPY hackathon /hackathon
