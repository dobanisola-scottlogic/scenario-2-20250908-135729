{
  "name": "ui",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "test": "suppress-exit-code cucumber-js -p default",
    "posttest": "node test/cucumber.report.js",
    "build": "tsc && vite build",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "lint:fix": "eslint . --ext ts,tsx --fix",
    "prettier:check": "prettier src/**/*.{ts,tsx} --check",
    "prettier:write": "prettier src/**/*.{ts,tsx} --write",
    "format": "npm run prettier:check && npm run lint",
    "format:fix": "npm run prettier:write && npm run lint:fix",
    "preview": "vite preview"
  },
  "dependencies": {
    "@cucumber/cucumber": "^9.4.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.37.1",
    "@types/react": "^18.2.15",
    "@types/react-dom": "^18.2.7",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "@vitejs/plugin-react": "^4.0.3",
    "eslint": "^8.47.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-react": "^7.33.2",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.3",
    "multiple-cucumber-html-reporter": "^3.4.0",
    "prettier": "3.0.2",
    "suppress-exit-code": "^3.2.0",
    "ts-node": "^10.9.1",
    "typescript": "^5.0.2",
    "vite": "^4.4.5"
  }
}
